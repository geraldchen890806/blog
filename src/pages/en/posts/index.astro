---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";
import { byLang, useTranslations } from "@/i18n";

const t = useTranslations("en");

const allPosts = await getCollection(
  "blog",
  post => !post.data.draft && byLang("en")(post)
);
const sortedPosts = getSortedPosts(allPosts);
const pageSize = SITE.postPerPage;
const lastPage = Math.max(1, Math.ceil(sortedPosts.length / pageSize));
const data = sortedPosts.slice(0, pageSize);

const page = {
  data,
  currentPage: 1,
  lastPage,
  size: pageSize,
  total: sortedPosts.length,
  start: 0,
  end: data.length - 1,
  url: {
    current: "/en/posts/",
    prev: undefined,
    next: lastPage > 1 ? "/en/posts/page/2/" : undefined,
    first: "/en/posts/",
    last: lastPage > 1 ? `/en/posts/page/${lastPage}/` : "/en/posts/",
  },
};

const pageTitle = `Posts | ${t("siteTitle")}`;
const pageDesc = `All articles on ${t("siteTitle")}: frontend development, AI agents, performance, security, and more.`;
---

<Layout title={pageTitle} description={pageDesc} alternateURL="/posts/">
  <Header />
  <Main pageTitle="Posts" pageDesc="All the articles I've posted.">
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />

  <script>
    function checkReadStatus() {
      const readPosts = JSON.parse(localStorage.getItem("readPosts") || "[]");
      const postCards = document.querySelectorAll(".post-card");

      postCards.forEach(card => {
        const postPath = card.getAttribute("data-post-path");
        const isRead =
          readPosts.includes(postPath) || readPosts.includes(postPath + "/");

        if (isRead) {
          const badge = card.querySelector(".read-badge");
          if (badge) {
            badge.classList.remove("hidden");
          }
        }
      });
    }

    checkReadStatus();
    document.addEventListener("astro:page-load", checkReadStatus);
  </script>
</Layout>
