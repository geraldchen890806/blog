---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";
import { byLang, useTranslations } from "@/i18n";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog", byLang("en"));
  const tags = getUniqueTags(posts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);

    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const t = useTranslations("en");
const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;
const pageNum = page.currentPage;
const tagPageTitle =
  pageNum > 1
    ? `Tag: ${tagName} - Page ${pageNum} | ${t("siteTitle")}`
    : `Tag: ${tagName} | ${t("siteTitle")}`;
const tagPageDesc =
  pageNum > 1
    ? `Articles tagged "${tagName}" on ${t("siteTitle")}, page ${pageNum}.`
    : `All articles tagged "${tagName}" on ${t("siteTitle")}.`;
---

<Layout noindex title={tagPageTitle} description={tagPageDesc}>
  <Header />
  <Main
    pageTitle={[`Tag:`, `${tagName}`]}
    titleTransition={tag}
    pageDesc={`All the articles with the tag "${tagName}".`}
  >
    <h1 slot="title" transition:name={tag}>{`Tag:${tag}`}</h1>
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>

<script>
  function checkReadStatus() {
    const readPosts = JSON.parse(localStorage.getItem("readPosts") || "[]");
    const postCards = document.querySelectorAll(".post-card");

    postCards.forEach(card => {
      const postPath = card.getAttribute("data-post-path");
      if (postPath && readPosts.includes(postPath)) {
        const badge = card.querySelector(".read-badge");
        if (badge) {
          badge.classList.remove("hidden");
        }
      }
    });
  }

  checkReadStatus();
  document.addEventListener("astro:page-load", checkReadStatus);
</script>
