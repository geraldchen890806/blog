---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Tag from "@/components/Tag.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import { byLang, useTranslations } from "@/i18n";

const t = useTranslations("en");

const posts = await getCollection("blog", byLang("en"));

let tags = getUniqueTags(posts);
---

<Layout
  title={`Tags | ${t("siteTitle")}`}
  description={`All tags on ${t("siteTitle")}: browse articles by topic — frontend, AI, agents, performance, security, and more.`}
  alternateURL="/tags/"
>
  <Header />
  <Main pageTitle="Tags" pageDesc="All the tags used in posts.">
    <ul class="flex flex-wrap gap-6">
      {tags.map(({ tag, tagName }) => <Tag {tag} {tagName} />)}
    </ul>
  </Main>
  <Footer />
</Layout>
