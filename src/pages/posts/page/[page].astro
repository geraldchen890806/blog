---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

export const getStaticPaths = (async () => {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const sortedPosts = getSortedPosts(allPosts);
  const pageSize = SITE.postPerPage;
  const lastPage = Math.max(1, Math.ceil(sortedPosts.length / pageSize));

  const paths = [];
  for (let pageNum = 2; pageNum <= lastPage; pageNum++) {
    const start = (pageNum - 1) * pageSize;
    const end = start + pageSize;
    const data = sortedPosts.slice(start, end);
    paths.push({
      params: { page: String(pageNum) },
      props: {
        page: {
          data,
          currentPage: pageNum,
          lastPage,
          size: pageSize,
          total: sortedPosts.length,
          start,
          end: start + data.length - 1,
          url: {
            current: `/posts/page/${pageNum}/`,
            prev:
              pageNum === 2 ? "/posts/" : `/posts/page/${pageNum - 1}/`,
            next:
              pageNum < lastPage ? `/posts/page/${pageNum + 1}/` : undefined,
            first: "/posts/",
            last: lastPage > 1 ? `/posts/page/${lastPage}/` : "/posts/",
          },
        },
      },
    });
  }
  return paths;
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const pageNum = page.currentPage;
const pageTitle = `文章列表 第 ${pageNum} 页 | ${SITE.title}`;
const pageDesc = `${SITE.title} 文章列表第 ${pageNum} 页，共 ${page.lastPage} 页。`;
---

<Layout title={pageTitle} description={pageDesc}>
  <Header />
  <Main pageTitle="Posts" pageDesc="All the articles I've posted.">
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />

  <script>
    function checkReadStatus() {
      const readPosts = JSON.parse(localStorage.getItem("readPosts") || "[]");
      const postCards = document.querySelectorAll(".post-card");

      postCards.forEach(card => {
        const postPath = card.getAttribute("data-post-path");
        const isRead =
          readPosts.includes(postPath) || readPosts.includes(postPath + "/");

        if (isRead) {
          const badge = card.querySelector(".read-badge");
          if (badge) {
            badge.classList.remove("hidden");
          }
        }
      });
    }

    checkReadStatus();
    document.addEventListener("astro:page-load", checkReadStatus);
  </script>
</Layout>
