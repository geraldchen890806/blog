---
// Appreciation component - 赞赏入口 (ETH/EVM)
---

<div class="appreciation-wrapper" data-pagefind-ignore>
  <button id="appreciation-toggle" class="appreciation-btn" aria-expanded="false">
    ☕ 觉得有帮助？请作者喝杯咖啡
  </button>
  <div id="appreciation-panel" class="appreciation-panel" hidden>
    <img
      src="/assets/eth-reward.jpg"
      alt="Ethereum Donation QR Code"
      class="appreciation-qr"
      loading="lazy"
      width="240"
      height="320"
    />
    <div class="appreciation-address">
      <code id="eth-address">0x320B48341e92D120276ff960F347EAe840bd4d6D</code>
      <button id="copy-address" class="copy-btn" title="Copy address">📋</button>
    </div>
  </div>
</div>

<style>
  .appreciation-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 1.5rem 0;
  }

  .appreciation-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
    color: #3b82f6;
    transition: opacity 0.2s;
    padding: 0.5rem 1rem;
    font-family: inherit;
    font-weight: 500;
  }

  .appreciation-btn:hover {
    opacity: 0.75;
    text-decoration: underline;
  }

  .appreciation-panel {
    margin-top: 0.75rem;
    text-align: center;
    animation: fadeIn 0.3s ease;
  }

  .appreciation-qr {
    max-width: 240px;
    border-radius: 8px;
  }

  .appreciation-address {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .appreciation-address code {
    font-size: 0.7rem;
    word-break: break-all;
    color: var(--color-text-muted, #666);
  }

  .copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.15rem 0.3rem;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .copy-btn:hover {
    opacity: 1;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline>
  document.getElementById('appreciation-toggle')?.addEventListener('click', function() {
    const panel = document.getElementById('appreciation-panel');
    if (!panel) return;
    const expanded = this.getAttribute('aria-expanded') === 'true';
    this.setAttribute('aria-expanded', String(!expanded));
    panel.hidden = expanded;
  });

  document.getElementById('copy-address')?.addEventListener('click', function() {
    const addr = document.getElementById('eth-address')?.textContent;
    if (addr) {
      navigator.clipboard.writeText(addr).then(() => {
        this.textContent = '✅';
        setTimeout(() => { this.textContent = '📋'; }, 1500);
      });
    }
  });
</script>
