---
// Appreciation component - 赞赏弹窗 (ETH/EVM)
import { getLangFromUrl, useTranslations } from "@/i18n";

const t = useTranslations(getLangFromUrl(Astro.url.pathname));
---

<div class="appreciation-wrapper" data-pagefind-ignore>
  <button id="appreciation-toggle" class="appreciation-btn">
    {t("appreciationButton")}
  </button>

  <!-- 遮罩 + 弹窗 -->
  <div id="appreciation-overlay" class="appreciation-overlay" hidden>
    <div class="appreciation-modal">
      <button id="appreciation-close" class="modal-close" aria-label="Close">&times;</button>
      <div class="modal-icon">◇</div>
      <h3 class="modal-title">{t("appreciationTitle")}</h3>
      <p class="modal-subtitle">{t("appreciationSubtitle")}</p>
      <img
        src="/assets/eth-reward.jpg"
        alt="Ethereum Donation QR Code"
        class="modal-qr"
        loading="lazy"
      />
      <code class="modal-address" id="eth-address">0x320B48341e92D120276ff960F347EAe840bd4d6D</code>
      <button
        id="copy-address"
        class="copy-btn"
        data-label-copy={t("appreciationCopy")}
        data-label-copied={t("appreciationCopied")}
      >
        {t("appreciationCopy")}
      </button>
      <p class="modal-note">{t("appreciationNote")}</p>
    </div>
  </div>
</div>

<style>
  .appreciation-wrapper {
    display: flex;
    justify-content: center;
    margin: 1.5rem 0;
  }

  .appreciation-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
    color: #3b82f6;
    padding: 0.5rem 1rem;
    font-family: inherit;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .appreciation-btn:hover {
    opacity: 0.75;
    text-decoration: underline;
  }

  /* 遮罩层 */
  .appreciation-overlay {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    animation: fadeIn 0.2s ease;
  }

  /* 弹窗 */
  .appreciation-modal {
    position: relative;
    background: #fff;
    border-radius: 16px;
    padding: 2rem 2.5rem;
    max-width: 380px;
    width: 90%;
    text-align: center;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    animation: slideUp 0.3s ease;
  }

  .modal-close {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #999;
    line-height: 1;
    padding: 0.25rem;
    transition: color 0.2s;
  }

  .modal-close:hover {
    color: #333;
  }

  .modal-icon {
    font-size: 1.5rem;
    color: #627eea;
    margin-bottom: 0.5rem;
  }

  .modal-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.25rem;
  }

  .modal-subtitle {
    font-size: 0.85rem;
    color: #888;
    margin: 0 0 1.25rem;
  }

  .modal-qr {
    width: 200px;
    height: 200px;
    object-fit: contain;
    border-radius: 4px;
    margin: 0 auto;
    display: block;
  }

  .modal-address {
    display: block;
    font-size: 0.65rem;
    color: #888;
    word-break: break-all;
    margin: 1rem 0 0.75rem;
    line-height: 1.4;
  }

  .copy-btn {
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 0.4rem 1.2rem;
    font-size: 0.85rem;
    cursor: pointer;
    color: #333;
    font-family: inherit;
    transition: all 0.2s;
  }

  .copy-btn:hover {
    border-color: #627eea;
    color: #627eea;
  }

  .modal-note {
    font-size: 0.75rem;
    color: #aaa;
    margin: 0.75rem 0 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline>
  function initAppreciation() {
    var toggle = document.getElementById('appreciation-toggle');
    var overlay = document.getElementById('appreciation-overlay');
    var closeBtn = document.getElementById('appreciation-close');
    var copyBtn = document.getElementById('copy-address');
    var addr = document.getElementById('eth-address');

    if (!toggle || toggle._bound) return;
    toggle._bound = true;

    function open() { if (overlay) overlay.hidden = false; }
    function close() { if (overlay) overlay.hidden = true; }

    toggle.addEventListener('click', open);
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (overlay) overlay.addEventListener('click', function(e) {
      if (e.target === overlay) close();
    });

    if (copyBtn && addr) {
      copyBtn.addEventListener('click', function() {
        navigator.clipboard.writeText(addr.textContent).then(function() {
          copyBtn.textContent = copyBtn.dataset.labelCopied;
          setTimeout(function() { copyBtn.textContent = copyBtn.dataset.labelCopy; }, 1500);
        });
      });
    }
  }
  initAppreciation();
  document.addEventListener('astro:page-load', initAppreciation);
</script>
