---
import { type CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";

type Props = {
  currentPost: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
  maxResults?: number;
};

const { currentPost, posts, maxResults = 3 } = Astro.props;

const currentTags = currentPost.data.tags ?? [];

const scored = posts
  .filter(p => p.id !== currentPost.id && !p.data.draft)
  .map(p => {
    const overlap = (p.data.tags ?? []).filter(t =>
      currentTags.includes(t)
    ).length;
    return { post: p, score: overlap };
  })
  .filter(item => item.score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return (
      new Date(b.post.data.pubDatetime).getTime() -
      new Date(a.post.data.pubDatetime).getTime()
    );
  })
  .slice(0, maxResults);
---

{
  scored.length > 0 && (
    <section class="related-posts" data-pagefind-ignore>
      <h2 class="related-title">相关阅读</h2>
      <ul class="related-list">
        {scored.map(({ post }) => (
          <li class="related-item">
            <a
              href={getPath(post.id, post.filePath, true, post.data.slug)}
              class="related-link"
            >
              <span class="related-post-title">{post.data.title}</span>
              <span class="related-desc">{post.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}

<style>
  .related-posts {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-card, var(--color-fill));
  }

  .related-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
    color: var(--color-text-base);
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-item {
    margin: 0;
  }

  .related-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem;
    border-radius: 0.375rem;
    text-decoration: none;
    color: var(--color-text-base);
    transition:
      background 0.15s,
      transform 0.15s;
    border-left: 3px solid transparent;
  }

  .related-link:hover {
    background: var(--color-fill);
    border-left-color: var(--color-accent);
  }

  .related-post-title {
    font-weight: 600;
    color: var(--color-accent);
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .related-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
